#!/bin/bash
set -e

# ----------------------------------------------------------------------------
# Set this ONCE to match whichever desktop this machine actually runs.
# If you ever abandon your current desktop for another, change this one
# line and everything below keeps working exactly the same.
#   plasma | gnome | budgie
# ----------------------------------------------------------------------------
DESKTOP="plasma"

case "$DESKTOP" in
    plasma)
        DESKTOP_SESSION_FILE="plasma.desktop"
        desktop_logout() {
            qdbus6 org.kde.Shutdown /Shutdown org.kde.Shutdown.logout 2>/dev/null \
                || qdbus-qt6 org.kde.Shutdown /Shutdown org.kde.Shutdown.logout
        }
        ;;
    gnome)
        DESKTOP_SESSION_FILE="gnome.desktop"
        desktop_logout() {
            gnome-session-quit --no-prompt
        }
        ;;
    budgie)
        DESKTOP_SESSION_FILE="budgie-desktop.desktop"
        desktop_logout() {
            budgie-session-quit --no-prompt
        }
        ;;
    *)
        echo >&2 "!! Unknown DESKTOP='$DESKTOP' - edit the variable at the top of this script"
        exit 1
        ;;
esac

case "$1" in
    'persistent')
        systemctl --user mask cachyos-gamescope-autologin.service
        pkexec /usr/lib/steamos/steam-set-session "$DESKTOP_SESSION_FILE";;
    'oneshot')
        systemctl --user unmask cachyos-gamescope-autologin.service
        pkexec /usr/lib/steamos/steam-set-session gamescope-session.desktop;;
    'gamescope')
        pkexec /usr/lib/steamos/steam-set-session gamescope-session.desktop
        desktop_logout;;
    'plasma')
        pkexec /usr/lib/steamos/steam-set-session "$DESKTOP_SESSION_FILE"
        steam -shutdown
        systemctl --user stop gamescope-session.target;;
    *)
        [[ -n "$1" ]] && echo -e "Unknown session '$1'\n"
        cat <<EOF
Usage: $(basename "$0") <mode>

Modes:
  persistent
      Enable persistent session mode.
      The system will remember the last session you used and boot into it
      next time. If you last used Gamescope, it will boot into Gamescope.
      If you last used the desktop, it will boot into the desktop.

  oneshot
      Restore default oneshot behaviour.
      Every fresh boot will start in Gamescope first, regardless of the
      previously used session.

  gamescope
      Immediately switch to the Gamescope session.

  plasma
      Immediately switch to the desktop session.
      This is the same action triggered by Steam's "Switch to Desktop".
      (Named 'plasma' for compatibility with Steam's hardcoded call, even
      when DESKTOP above is set to gnome or budgie.)

Example:
    $(basename "$0") persistent
EOF
        exit 1;;
esac

if [[ -e /dev/input/.hidden ]]; then
    echo "Unhide hidden controller devices as needed"
    pkexec mv /dev/input/.hidden/* /dev/input
    pkexec rm -r /dev/input/.hidden
fi
