#!/bin/bash
set -e

# ------------------------------------------------------------------
# 1. Verificar que GDM esté activo antes de hacer nada
# ------------------------------------------------------------------
if ! systemctl is-active --quiet gdm; then
    echo "gdm no está activo, abortando." >&2
    exit 1
fi

# ------------------------------------------------------------------
# 2. Determinar el usuario de forma robusta
# ------------------------------------------------------------------
USER_NAME="${GDMUSER:-${SUDO_USER:-$(logname 2>/dev/null || whoami)}}"
: "${USER_NAME:?No se pudo determinar el usuario}"

# ------------------------------------------------------------------
# 3. Configuración de la Sesión en AccountsService (Wayland Puro)
# ------------------------------------------------------------------
ACCOUNTS_USER_FILE="/var/lib/AccountsService/users/$USER_NAME"

[[ -f "$ACCOUNTS_USER_FILE" ]] || {
    echo "Error: No existe $ACCOUNTS_USER_FILE" >&2
    exit 1
}

SESSION="${1:-gamescope-session}"

set_or_add() {
    local file="$1"
    local key="$2"
    local value="$3"
    local section="$4"

    if grep -q "^${key}=" "$file"; then
        sed -i "s|^${key}=.*|${key}=${value}|" "$file"
    else
        sed -i "/^\[${section}\]/a ${key}=${value}" "$file"
    fi
}

set_or_add "$ACCOUNTS_USER_FILE" "Session" "$SESSION" "User"

# ------------------------------------------------------------------
# 4. Configuración del Autologin (TimedLogin) en custom.conf
# ------------------------------------------------------------------
CONF_FILE="/etc/gdm/custom.conf"

if [[ -f "$CONF_FILE" ]]; then
    set_or_add "$CONF_FILE" "TimedLoginEnable" "true" "daemon"
    set_or_add "$CONF_FILE" "TimedLoginDelay" "1" "daemon"
    set_or_add "$CONF_FILE" "TimedLogin" "$USER_NAME" "daemon"
fi
